{
	"name": "cbuntingde/classic-editor",
	"description": "Enables the WordPress classic editor with PHP 8.2+ modern standards.",
	"type": "wordpress-plugin",
	"license": "GPL-2.0-or-later",
	"require": {
		"php": ">=8.2"
	},
	"require-dev": {
		"phpstan/phpstan": "^1.10",
		"squizlabs/php_codesniffer": "^3.7",
		"wp-coding-standards/wpcs": "^3.0"
	},
	"config": {
		"allow-plugins": {
			"dealerdirect/phpcodesniffer-composer-installer": true
		}
	},
	"scripts": {
		"phpcs": "phpcs --standard=WordPress classic-editor.php",
		"phpcbf": "phpcbf --standard=WordPress classic-editor.php",
		"phpstan": "phpstan analyse --configuration=phpstan.neon"
	}
}